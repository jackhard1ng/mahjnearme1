rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the requesting user is an admin
    function isAdmin() {
      return request.auth != null &&
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'admin';
    }

    // Helper: check if user is authenticated
    function isAuthed() {
      return request.auth != null;
    }

    // ----------------------------------------------------------------
    // listings — public read, server-only write (Admin SDK bypasses rules)
    // Admin users can also write via client SDK (for admin dashboard)
    // ----------------------------------------------------------------
    match /listings/{listingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ----------------------------------------------------------------
    // organizers — public read, server-only write
    // ----------------------------------------------------------------
    match /organizers/{organizerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ----------------------------------------------------------------
    // users — each user can read/write their own profile; admin can read all
    // ----------------------------------------------------------------
    match /users/{userId} {
      allow read: if isAuthed() && (request.auth.uid == userId || isAdmin());
      allow write: if isAuthed() && request.auth.uid == userId;
    }

    // ----------------------------------------------------------------
    // approvals — owner can read their own pending approvals; admin manages
    // ----------------------------------------------------------------
    match /approvals/{approvalId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }

    // ----------------------------------------------------------------
    // claims — owner can read their own; admin manages
    // ----------------------------------------------------------------
    match /claims/{claimId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }

    // ----------------------------------------------------------------
    // organizerApplications — applicant can read their own; admin manages
    // ----------------------------------------------------------------
    match /organizerApplications/{appId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }

    // ----------------------------------------------------------------
    // analytics — any visitor can write page views; admin can read
    // Intentionally permissive writes: analytics should never block UX
    // ----------------------------------------------------------------
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // ----------------------------------------------------------------
    // forum — authenticated users can read/write posts
    // ----------------------------------------------------------------
    match /forum/{postId} {
      allow read: if true;
      allow create: if isAuthed() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // ----------------------------------------------------------------
    // Everything else — admin only
    // ----------------------------------------------------------------
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
